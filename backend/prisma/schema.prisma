generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                      Int            @id @default(autoincrement())
  name                    String
  email                   String         @unique
  password                String
  role                    String
  createdAt               DateTime       @default(now())

  contributions           Contribution[] @relation("UserContributions")
  registeredContributions Contribution[] @relation("RegisteredContributions")
}

model Contribution {
  id               Int      @id @default(autoincrement())
  amount           Decimal  @db.Decimal(10, 2)
  paymentMethod    String
  contributionDate DateTime
  createdAt        DateTime @default(now())

  userId         Int
  registeredById Int?

  user         User  @relation("UserContributions", fields: [userId], references: [id])
  registeredBy User? @relation("RegisteredContributions", fields: [registeredById], references: [id])
}